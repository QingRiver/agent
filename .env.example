# 复制为 .env 后填写真实值：cp .env.example .env
# 本文件为 monorepo 共享配置（server、packages/cli、packages/graph 等均从此读取）
# 可选：apps/server/.env 仅覆盖 server 专有项（PORT、DATA_DIR 等）

# --- LLM（DeepSeek OpenAI 兼容）https://platform.deepseek.com/api_keys ---
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_MODEL=deepseek-v4-flash
OPENAI_MODEL_MINI=deepseek-v4-flash
OPENAI_BASE_URL=https://api.deepseek.com

# --- Claude Agent SDK ---
ANTHROPIC_AUTH_TOKEN=sk-your-key
ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-flash

# --- Tushare（A 股行情 MCP）https://tushare.pro 用户中心获取 token ---
TUSHARE_TOKEN=your-tushare-token
TUSHARE_REQUEST_INTERVAL_SEC=5
TUSHARE_REQUEST_INTERVAL_STEP_SEC=5
TUSHARE_REQUEST_INTERVAL_MAX_SEC=20

# --- Qlib Data Service (infra/qlib/) ---
QLIB_DATA_DIR=infra/qlib/qlib_data/cn_data
QLIB_API_PORT=8000

# --- Knowledge Base (infra/qdrant + infra/markitdown) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_PORT=6333
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn
KB_EMBEDDING_MODEL=BAAI/bge-m3
KB_RERANK_MODEL=BAAI/bge-reranker-v2-m3
KB_MARKITDOWN_URL=http://localhost:8200
KB_MARKITDOWN_PORT=8200
KB_COLLECTION=kb_default
KB_RECALL_K=20
KB_RERANK_TOPK=5
KB_RERANK_MIN_SCORE=0.3

# --- PostgreSQL (infra/postgres/) ---
# better-auth + drizzle(conversation_threads) + langgraph checkpoint 共用
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent

# --- Redis (infra/redis/) ---
# gtd 缓存（派生状态/透视/文档快照）+ 分布式锁；dev 默认无密码
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- Server ---
PORT=3000
BETTER_AUTH_SECRET=replace-with-random-32-chars-minimum
BETTER_AUTH_URL=https://localhost:3000
DATA_DIR=apps/server/data
# E2E 测试账号（pnpm devops e2e auth 写入 postgres）：agent-e2e@cursor.local / agent-e2e-pass
# 基础设施与 E2E 统一入口：pnpm devops --help（见 .cursor/skills/devops/SKILL.md）
