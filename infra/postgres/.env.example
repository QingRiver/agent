# PostgreSQL（infra/postgres/）
# 共享配置从仓库根 .env 读取（docker-compose env_file: ../../.env）

# 宿主机映射端口（默认 5432）
POSTGRES_PORT=5432

# 超级用户与默认库（容器初始化用；首次建卷时生效，之后改需重建卷）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent

# Node 客户端连接串（根 .env，server 的 drizzle / better-auth / langgraph 共用）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent
